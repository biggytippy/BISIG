{
	"info": {
		"_postman_id": "8488e0b6-12a8-4c8d-8a8b-b8c067d26dfd",
		"name": "BISIG API Functional Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "API Root Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Response contains welcome message\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.contains(\"Welcome to the BISIG\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8000/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "Translate Hello",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Response contains correct original text\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.original_text).to.eql(\"hello\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8000/translate?text=hello&format=full_skeleton",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"translate"
					],
					"query": [
						{
							"key": "text",
							"value": "hello"
						},
						{
							"key": "format",
							"value": "full_skeleton"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Translate Empty String",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 400\", function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"pm.test(\"Response contains empty text error\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.detail).to.eql(\"Text cannot be empty\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8000/translate?text=%20",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"translate"
					],
					"query": [
						{
							"key": "text",
							"value": " "
						}
					]
				}
			},
			"response": []
		}
	]
}
